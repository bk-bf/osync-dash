# osync-dash pinned dependency versions.
#
# Keeping every osync-dash node — and the remotes it deploys to — on the SAME
# osync build means behaviour and, crucially, the log format are identical
# everywhere, so osync-dash can parse osync's output robustly. Bump these to
# upgrade; re-run install.sh to apply.

OSYNC_REPO="https://github.com/deajan/osync.git"
OSYNC_VERSION="v1.3"        # git tag/branch of deajan/osync to vendor
OSYNC_BUILD="2023061401"    # expected build stamp (osync.sh --version), informational

TEXTUAL_VERSION="8.2.8"     # Textual pinned for the TUI virtualenv
